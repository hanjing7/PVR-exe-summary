<html><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    
    <meta name="color-scheme" content="light dark">
    <meta name="viewport" content="initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MCP-UI Proxy</title>
    <style>
      html,
      body {
        margin: 0;
        height: 100vh;
        width: 100vw;
      }
      body {
        display: flex;
        flex-direction: column;
      }
      * {
        box-sizing: border-box;
      }
      iframe {
        background-color: transparent;
        border: 0px none transparent;
        padding: 0px;
        overflow: hidden;
        flex-grow: 1;
      }
    </style>
  <style>.village-iframe{width:100%;height:100%;border:none;display:block;position:fixed;top:0;left:0;z-index:2147483647;background:#0000003d;color-scheme:light}.village-iframe.village-loading{display:flex;justify-content:center;align-items:center}.village-iframe>.village-spinner{width:1.5rem;height:1.5rem;border:2px solid #000;border-left-color:transparent;border-bottom-color:transparent;border-radius:50%;animation:spin .45s linear infinite}.village-iframe.village-hidden{display:none}@keyframes spin{0%{transform:rotate(0)}to{transform:rotate(360deg)}}.village-hidden{display:none}[village-paths-data=facepiles]{display:flex;align-items:center;padding-right:.5rem}[village-paths-data=facepiles] img{width:1.5rem;height:1.5rem;border-radius:50%;margin-right:-.5rem}[village-paths-data=facepiles] img.village-facepiler-avatar-not-found{filter:blur(7px)}[village-paths-data=facepiles] img:last-child{margin-right:0}[village-paths-data=count]{padding-right:.25rem}[village-paths-availability=error],[village-paths-availability=found],[village-paths-availability=not-found],[village-paths-availability=not-activated]{display:none!important}[village-paths-availability=loading]{display:inline-flex!important}</style></head>
  <body>
    <script>
      // Double-iframe raw HTML mode (HTML sent via postMessage)
      const inner = document.createElement('iframe');
      inner.style = 'width:100%; height:100%; border:none;';
      inner.setAttribute('sandbox', 'allow-scripts allow-same-origin allow-forms');
      document.body.appendChild(inner);

      let parentOrigin = '*';

      const ALLOWED_ORIGIN_PATTERNS = ["https://claude.ai","https://preview.claude.ai"];

      const isAllowedOrigin = function(origin) {
        try {
          const url = new URL(origin);
          const originHost = url.host;
          const originScheme = url.protocol.replace(':', '');
          return ALLOWED_ORIGIN_PATTERNS.some(pattern => {
            const [patternScheme, patternHost] = pattern.split('://');
            if (originScheme !== patternScheme) return false;
            if (patternHost === 'localhost:*') {
              return originHost.startsWith('localhost:') || originHost === 'localhost';
            }
            if (patternHost.startsWith('*.')) {
              const baseDomain = patternHost.slice(2);
              return originHost === baseDomain || originHost.endsWith('.' + baseDomain);
            }
            return originHost === patternHost;
          });
        } catch {
          return false;
        }
      };

      // Build Permission Policy allow attribute from permissions object.
      // Maps McpUiResourcePermissions keys to Permission Policy feature names.
      // Uses '*' suffix for cross-origin permission delegation.
      //
      // NOTE: This is duplicated from packages/mcp-ext-apps-host/app-host-utils.ts
      // because this runs as inline JS in the browser. Keep both in sync!
      const buildAllowAttribute = function(permissions) {
        if (!permissions || typeof permissions !== 'object') return '';
        const mapping = {
          camera: 'camera',
          microphone: 'microphone',
          geolocation: 'geolocation',
          clipboardWrite: 'clipboard-write',
        };
        const features = Object.keys(permissions)
          .filter(key => mapping[key] && permissions[key] != null)
          .map(key => mapping[key] + ' *');
        return features.join('; ');
      };

      // IncrementalJsonParser for healing streamed tool-input deltas.
      // When the host sends raw JSON text deltas (tool-input-delta), the sandbox
      // feeds them through this parser and forwards the healed result to the view
      // as a standard tool-input-partial notification.
