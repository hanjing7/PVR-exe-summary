`||e==="\r"))switch(e){case"{":this.clearTrailingComma(),this.stack.push({phase:0,lastEntryEnd:i+1});break;case"[":this.clearTrailingComma(),this.stack.push({phase:10,lastEntryEnd:i+1});break;case"}":{const s=this.topFrame();s&&(s.phase===0||s.phase===3)&&(this.stack.pop(),this.valueCompleted(i+1));break}case"]":{const s=this.topFrame();s&&(s.phase===10||s.phase===11)&&(this.stack.pop(),this.valueCompleted(i+1));break}case":":{const s=this.topFrame();s&&s.phase===2&&(s.phase=1);break}case",":{const s=this.topFrame();s&&(s.phase===3?s.phase=4:s.phase===11&&(s.phase=12),this.trailingCommaIndex=i);break}case'"':this.clearTrailingComma(),this.tokenType=1;break;default:if(e==="-"||e>="0"&&e<="9"){this.clearTrailingComma(),this.tokenType=4,e==="-"?this.numPhase=0:e==="0"?this.numPhase=1:this.numPhase=2;break}e==="t"?(this.clearTrailingComma(),this.tokenType=5,this.literalTarget="true",this.literalIndex=1):e==="f"?(this.clearTrailingComma(),this.tokenType=5,this.literalTarget="false",this.literalIndex=1):e==="n"&&(this.clearTrailingComma(),this.tokenType=5,this.literalTarget="null",this.literalIndex=1);break}}topFrame(){return this.stack.length>0?this.stack[this.stack.length-1]:null}clearTrailingComma(){this.trailingCommaIndex>=0&&(this.trailingCommaIndex=-1)}valueCompleted(e){if(this.stack.length===0){this.complete=!0;return}const i=this.stack[this.stack.length-1];switch(i.phase){case 1:i.phase=3,i.lastEntryEnd=e;break;case 10:case 12:i.phase=11;break}}}

      const jsonParser = new IncrementalJsonParser();

      // Handle messages from the parent (web: claude.ai via postMessage, mobile: native app via mcpAppBridgeReceive).
      // onHandshake is called once during sandbox-resource-ready to lock in the parent origin (web only).
      const handleParentMessage = function(data, onHandshake) {
        if (data && data.method === 'ui/notifications/sandbox-resource-ready') {
          const {html, permissions} = data.params;
          if (typeof html === 'string') {
            if (onHandshake) onHandshake();
            // Set allow attribute for Permission Policy features
            const allowValue = buildAllowAttribute(permissions);
            if (allowValue) {
              inner.setAttribute('allow', allowValue);
            }

            // Use document.write() instead of srcdoc to preserve origin.
            // srcdoc creates an opaque origin that breaks WebGL canvas operations
            // like toDataURL() and cross-origin resource access.
            const doc = inner.contentDocument;
            doc.open();
            doc.write(html);
            doc.close();
          }
        } else if (data && data.method === 'ui/notifications/tool-input-delta') {
          // Host sends raw JSON text deltas — heal and forward as tool-input-partial.
          // The view never sees tool-input-delta; it sees the specced tool-input-partial.
          const delta = data.params && data.params.delta;
          if (typeof delta === 'string' && delta.length > 0) {
            jsonParser.write(delta);
            const healed = jsonParser.getHealed();
            let args;
            try {
              args = JSON.parse(healed);
            } catch {
              console.error('[mcp_apps] healed tool-input-delta did not parse');
              return;
            }
            if (typeof args !== 'object' || args === null) {
              console.error('[mcp_apps] healed tool-input-delta was not an object');
              return;
            }
            if (inner && inner.contentWindow) {
              inner.contentWindow.postMessage({
                jsonrpc: '2.0',
                method: 'ui/notifications/tool-input-partial',
                params: { arguments: args },
              }, location.origin);
            }
          }
        } else {
          if (data && data.method === 'ui/notifications/tool-input') {
            jsonParser.reset();
          }
          if (inner && inner.contentWindow) {
            inner.contentWindow.postMessage(data, location.origin);
          }
        }
      };

      // Wait for HTML content from parent
      window.addEventListener('message', async (event) => {
        if (event.source === window.parent && isAllowedOrigin(event.origin)) {
          handleParentMessage(event.data, function() { parentOrigin = event.origin; });
        } else if (event.source === inner.contentWindow && event.origin === location.origin) {
          // Relay messages from inner to parent (srcdoc + allow-same-origin = same origin as parent)
          window.parent.postMessage(event.data, parentOrigin);
        }
      });

      // Notify parent that proxy is ready to receive HTML (distinct event)
      window.parent.postMessage({
        jsonrpc: "2.0",
        method: 'ui/notifications/sandbox-proxy-ready',
        params: {}
      }, '*');

    </script><iframe sandbox="allow-scripts allow-same-origin allow-forms" allow="clipboard-write *" style="width: 100%; height: 100%; border: none;" src="./saved_resource(5).html"></iframe>
  
